          "countryCode": "UN"
        },
        "legalBases": [],
        "effects": [
          {
            "@type": "SanctionEffect",
            "effectType": "asset_freeze",
            "scope": "full",
            "description": "All funds and economic resources belonging to or owned by this entity are frozen."
          },
          {
            "@type": "SanctionEffect",
            "effectType": "travel_ban",
            "scope": "full",
            "description": "Travel restrictions apply to this individual."
          }
