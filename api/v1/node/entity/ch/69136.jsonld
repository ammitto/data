  "names": [
    {
      "full_name": "Star Sapphire Group of Companies",
      "is_primary": true
    }
  ],
  "remarks": "The Star Sapphire Group of Companies plays an important role in generating income for the military regime and in providing arms and other equipment used by the armed forces. The group of companies is controlled by individuals linked to the Myanmar military and has been involved in a wide range of business sectors, including mining, manufacturing, defence, casinos, energy, agriculture and trade. The Star Sapphire Group of Companies therefore generates revenue for, provides support to and benefits from the Myanmar Armed Forces (Tatmadaw).",
  "@context": "https://www.ammitto.org/ontology/context.jsonld"
}