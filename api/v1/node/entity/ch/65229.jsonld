  "names": [
    {
      "full_name": "Karcheusky Siarhei Uladzimiravich",
      "is_primary": true
    }
  ],
  "remarks": "As head of the regime department of Penal Colony No 17 in Shklow, Siarhei Kharcheusky is directly responsible for the inhumane conditions of detention in the colony, for the violent practices and ill-treatment inflicted on prisoners, notably on political prisoners. He was personally involved in carrying out beatings and other acts of extreme violence against prisoners and he is directly involved in, and responsible for, the death of the political prisoner Vitold Ashurak in that penal colony on 21 May 2021. He is therefore responsible for serious violations of human rights and the repression of civil society in Belarus.",
  "birth_info": [
    {
      "date": "1983-06-15",
      "circa": false
    }
  ],
  "@context": "https://www.ammitto.org/ontology/context.jsonld"
}