  "names": [
    {
      "full_name": "Belteleradio Company / National State Television and Radio Company of the Republic of Belarus",
      "is_primary": true
    }
  ],
  "remarks": "Belteleradio Company is the state television and radio broadcasting company, and controls seven television channels and five radio stations in Belarus. In the aftermath of fraudulent presidential elections in Aug 2020, Belteleradio Company dismissed protesting workers of the media outlets it controls and replaced them with Russian media employees. It is therefore responsible for the repression of civil society. The television and radio stations supervised by Belteleradio Company are actively spreading propaganda and thus supporting the Lukashenka regime.",
  "@context": "https://www.ammitto.org/ontology/context.jsonld"
}