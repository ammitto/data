  "names": [
    {
      "full_name": "JSC Nauchnoproizvodstvennoe Obedinenie Russkie Bazovye Informacionnye Technologii (JSC RPA Rusbitech)",
      "is_primary": true
    }
  ],
  "remarks": "JSC RPA RUSBITECH is a Russian technology company specialising in the production of high technology solutions for Russian enforcement structures, mainly for Russian Armed Forces. Its best known product is the computer operating system called Astra Linux which is now used almost totally throughout Russian military forces. The main Russian Army Headquarters information systems are based on Astra Linux. The company is also known for manufacturing of APE-5 type command points actively used for communication in the field during Russia’s war of aggression against Ukraine.",
  "@context": "https://www.ammitto.org/ontology/context.jsonld"
}