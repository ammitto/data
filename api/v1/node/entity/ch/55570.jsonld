  "names": [
    {
      "full_name": "JSC \"121 Aircraft Repair Plant\"",
      "is_primary": true
    }
  ],
  "remarks": "121 Aircraft Repair Plant repairs Su-25, Su-27, MiG-29 and MiG-31 aircraft. It is the only enterprise in Russia that simultaneously repairs and upgrades Su-25 aircraft to the Su-25 SM version. Su-25 SM and MiG-31 were used by the Armed Forces of the Russian Federation during Russia’s war of aggression against Ukraine. Belarusian personnel have also been dispatched to this site to help repair combat aircraft so that they can be reused in Russia’s aggression in Ukraine.",
  "@context": "https://www.ammitto.org/ontology/context.jsonld"
}