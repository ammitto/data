  "names": [
    {
      "full_name": "National Iranian Oil Company (NIOC) PTE LTD",
      "is_primary": true
    }
  ],
  "remarks": "The National Iranian Oil Company PTE LTD is a subsidiary (100 %) of the state-owned and operated National Iranian Oil Company (NIOC). The National Iranian Oil Company (NIOC) is a State-owned and operated entity providing substantial financial resources to the Government of Iran. NIOC holds the production, sale and export monopoly for Iranian oil. The revenue generated by NIOC’s oil sales plays a significant role in funding Iran’s military and the IRGC. Therefore, the National Iranian Oil Company PTE LTD is owned or controlled by an entity providing support to the Government of Iran. It also provides essential services to the IRGC.",
  "@context": "https://www.ammitto.org/ontology/context.jsonld"
}