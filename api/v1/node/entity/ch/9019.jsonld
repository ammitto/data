  "entity_type": "organization",
  "names": [
    {
      "full_name": "Bank Saderat Iran (including all branches and subsidiaries)",
      "is_primary": true
    }
  ],
  "remarks": "By handling letters of credit of Defence Industries Organisation (DIO) in March 2009, Bank Saderat violated the provisions of UNSCR 1737 which designated DIO and therefore required the freezing of its, and prohibited the making available to it of any, funds, financial assets and economic ressources. By handling those letters of credit, Bank Saderat also assisted DIO in violating the prohibition contained in UNSCR 1747 on the procurement and the provision by Iran of any arms and related material.",
  "@context": "https://www.ammitto.org/ontology/context.jsonld"
}