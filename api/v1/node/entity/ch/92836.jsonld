  "names": [
    {
      "full_name": "Autonomous non-profit Organisation “Scientific and Production Center for Testing and Competence in the Field of Development of Unmanned Aircraft Systems and Means of Protection Against their Illegal Use ‘Ushkuynik’”",
      "is_primary": true
    }
  ],
  "remarks": "Scientific-Research Centre “Ushkuynik” is a company producing unmanned aerial vehicles (UAVs) to the benefit of the Russian military. Its main product is the UAV named “Kniaz Vandal Novgorodskiy” (KVN), which is used by Russia in its war of aggression against Ukraine. The company also holds permission from the Russian Government to unite and coordinate the efforts of UAV engineers and construction companies in order to create and test new types of UAV in Veliky Novgorod.",
  "@context": "https://www.ammitto.org/ontology/context.jsonld"
}