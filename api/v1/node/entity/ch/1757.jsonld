  "names": [
    {
      "full_name": "Roodi Slewa",
      "is_primary": true
    }
  ],
  "remarks": "In addition to serving as Uday Saddam Hussein’s partner in an Iraqi consumer goods company, Roodi Slewa played a key role in Uday Saddam Hussein’s illicit alcohol and cigarette distribution monopolies. Under the former regime, Iraqi cigarette and alcohol vendors were required to make extortion payments to Slewa in order to conduct business. Slewa paid Uday Saddam Hussein approximately $1.5 million per month from the proceeds of this racketeering scheme.",
  "@context": "https://www.ammitto.org/ontology/context.jsonld"
}