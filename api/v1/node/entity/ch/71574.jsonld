    {
      "full_name": "JSC “State Design Bureau ‘Vympel’ named after I.I. Toropov”",
      "is_primary": true
    }
  ],
  "remarks": "JSC “State Design Bureau ‘Vympel’ named after I.I. Toropov” is a specialised enterprise engaged in development and production of automated systems for the maintenance and control of weapons and military equipment. The enterprise is engaged in the development and manufacture of air-to-air and air-to-surface guided missiles, guided missiles for land and sea anti-aircraft systems, launchers, and catapults for airborne guided missiles, beam holders for suspension of aerial bomber armament and units for unguided aircraft missiles.",
  "@context": "https://www.ammitto.org/ontology/context.jsonld"
}