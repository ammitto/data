  "names": [
    {
      "full_name": "Tarabya Logistics Ltd",
      "is_primary": true
    }
  ],
  "remarks": "Tarabya Logistics Ltd is a UAE-based company which manages several vessels that have engaged in irregular and high-risk shipping practices, such as sailing with Automatic Identification Systems gaps and high-risk ship-to-ship transfers, while transporting oil originating in Russia or exported from Russia. Therefore, Tarabya Logistics Ltd is managing vessels that transport crude oil or petroleum products, originating in Russia or exported from Russia, while practicing irregular and high-risk shipping practices as set out in the International Maritime Organisation General Assembly resolution A.1192(33).",
  "@context": "https://www.ammitto.org/ontology/context.jsonld"
}