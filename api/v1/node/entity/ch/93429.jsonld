  "names": [
    {
      "full_name": "Joint Stock Company “Feodosia Optical Plant”",
      "is_primary": true
    }
  ],
  "remarks": "JSC “Feodosia Optical Plant” is a producer of optical and optoelectronic devices. It also produces components (including sight-guidance devices and rangefinders) used in military equipment, such as appliances that are part of the 1A40 and 1A40-1 rangefinder sights, which are installed on T-72 tanks used by the Russian military. JSC “Feodosia Optical Plant” is therefore supporting materially Russia’s military and industrial complex, which is responsible for the annexation of Crimea and the destabilisation of Ukraine.",
  "@context": "https://www.ammitto.org/ontology/context.jsonld"
}